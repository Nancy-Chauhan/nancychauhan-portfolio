---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/home/Hero.astro";
import Features from "../components/home/Features.astro";
import FeaturedProjects from "../components/home/FeaturedProjects.astro";
import RecentPosts from "../components/home/RecentPosts.astro";
import Talks from "../components/home/Talks.astro";
import Community from "../components/home/Community.astro";
import Testimonials from "../components/home/Testimonials.astro";
import LogoMarquee from "../components/home/LogoMarquee.astro";
import PhotoGallery from "../components/PhotoGallery.astro";
---

<BaseLayout title="Nancy Chauhan | Engineer & Product Builder">
  <Hero />
  <LogoMarquee />
  <div class="max-w-6xl mx-auto px-6 md:px-24 pb-24">
    <hr class="section-divider mb-16" />
    <Features />
    <hr class="section-divider my-16" />
    <FeaturedProjects />
    <hr class="section-divider my-16" />
    <RecentPosts />
    <hr class="section-divider my-16" />
    <Talks />
    <hr class="section-divider my-16" />
    <Community />
    <hr class="section-divider my-16" />
    <Testimonials />
    <hr class="section-divider my-16" />
    <div class="mb-10">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
        <div>
          <h2 class="text-2xl sm:text-3xl md:text-4xl font-extrabold font-sans tracking-tight mb-3 animate-on-scroll">
            <span class="section-heading">Unveiling Beauty, Art & Culture, One place at a Time 💜</span>
          </h2>
          <p class="text-base sm:text-lg text-[var(--color-stone-500)] font-sans animate-on-scroll">
            Its about the moments that's wrapped in it
          </p>
        </div>
      </div>
    </div>
    <PhotoGallery />
  </div>
</BaseLayout>
