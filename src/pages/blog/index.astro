---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogCard from "../../components/cards/BlogCard.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
---

<BaseLayout title="Blog — Nancy Chauhan">
  <section class="py-20">
    <div class="mx-auto max-w-6xl px-6">
      <h1 class="text-4xl md:text-5xl font-extrabold font-sans tracking-tight mb-4">
        <span class="section-heading">Writing</span>
      </h1>
      <p class="text-base text-[var(--color-stone-500)] font-sans max-w-2xl">
        Thinking out loud about distributed systems, cloud native infrastructure, developer tools, and lessons learned.
      </p>
    </div>
  </section>
  <div class="mx-auto max-w-6xl px-6 pb-20">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {posts.map((post, i) => (
        <div class={`animate-on-scroll stagger-${(i % 4) + 1}`}>
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            slug={post.id}
          />
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
