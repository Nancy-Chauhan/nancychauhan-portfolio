---
const skillGroups = [
  { category: "Languages", skills: ["Python", "TypeScript", "Go", "Java", "SQL"] },
  { category: "AI & ML", skills: ["LLM Observability", "AI Agents", "RAG", "Prompt Engineering"] },
  { category: "Infrastructure", skills: ["Kubernetes", "Docker", "Terraform", "AWS", "GCP"] },
  { category: "Security", skills: ["CI/CD Security", "SAST", "Vulnerability Management", "DevSecOps"] },
  { category: "Developer Relations", skills: ["Technical Writing", "Conference Speaking", "Community Building", "Developer Education"] },
  { category: "Frameworks & Tools", skills: ["React", "Next.js", "FastAPI", "Node.js", "Git"] },
];
---

<section>
  <h2 class="text-3xl md:text-4xl font-extrabold font-sans tracking-tight mb-8 animate-on-scroll">
    <span class="section-heading">Tech Stack</span>
  </h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    {skillGroups.map((group, i) => (
      <div class={`animate-on-scroll stagger-${i + 1} card-dashed p-6`}>
        <h3 class="font-sans text-sm font-bold uppercase tracking-widest text-[var(--color-stone-400)] mb-3">
          {group.category}
        </h3>
        <div class="flex flex-wrap gap-2">
          {group.skills.map((skill) => (
            <span class="tag-brutal">{skill}</span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
