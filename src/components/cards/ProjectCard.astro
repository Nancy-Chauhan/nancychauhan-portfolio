---
interface Props {
  title: string;
  tagline: string;
  techStack: string[];
  slug: string;
}

const { title, tagline, techStack, slug } = Astro.props;
---

<a
  href={`/projects/${slug}`}
  class="group block card-dashed overflow-hidden"
  transition:name={`project-${slug}`}
>
  {/* Window chrome bar */}
  <div class="window-chrome">
    <div class="window-dot" style="background:#ff5f57;"></div>
    <div class="window-dot" style="background:#febc2e;"></div>
    <div class="window-dot" style="background:#28c840;"></div>
    <span class="window-chrome-title">~/projects/{slug}</span>
  </div>

  <div class="px-5 pt-4 pb-5">
    <h3 class="text-lg font-bold font-sans text-[var(--color-stone-900)] mb-2 group-hover:text-[var(--color-purple)] transition-colors">
      {title}
    </h3>
    <p class="text-base text-[var(--color-stone-600)] font-sans leading-relaxed mb-4">
      {tagline}
    </p>
    <div class="flex flex-wrap gap-2 mb-4">
      {techStack.slice(0, 4).map((tech) => (
        <span class="tag-brutal">{tech}</span>
      ))}
    </div>
    <span class="terminal-link group-hover:gap-3 transition-all">
      explore
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </span>
  </div>
</a>
