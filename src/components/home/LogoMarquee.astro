---
// Each logo gets a tailored width to ensure equal visual weight
// Square icons get narrow widths, horizontal wordmarks get wider
const logos = [
  { name: "Arize AI", src: "/logos/arize.svg", style: "height:24px;width:auto;" },
  { name: "ONA", src: "/logos/ona.svg", style: "height:24px;width:auto;" },
  { name: "LocalStack", src: "/logos/localstack.svg", style: "height:26px;width:auto;" },
  { name: "Blinkit", src: "/logos/blinkit.svg", style: "height:24px;width:auto;" },
  { name: "Rootly", src: "/logos/rootly.png", style: "height:22px;width:auto;" },
  { name: "Exostellar", src: "/logos/exostellar.svg", style: "height:20px;width:auto;" },
  { name: "Processing Foundation", src: "/logos/processing-foundation.png", style: "height:36px;width:36px;" },
  { name: "FOSSi", src: "/logos/fossi.svg", style: "height:26px;width:auto;" },
  { name: "Zeotap", src: "/logos/zeotap.svg", style: "height:22px;width:auto;" },
];
---

<section class="py-12 mx-auto max-w-6xl px-6 md:px-24">
  <p class="text-center text-sm text-[var(--color-stone-400)] font-sans mb-8">
    Organisations I've worked and collaborated with
  </p>
  <div class="relative overflow-hidden">
    <div class="marquee-track flex items-center gap-14 w-max">
      {[...logos, ...logos].map((logo) => (
        <div class="logo-item shrink-0 flex items-center justify-center">
          <img src={logo.src} alt={logo.name} style={logo.style} class="object-contain" />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .marquee-track {
    animation: marquee 15s linear infinite;
  }

  .marquee-track:hover {
    animation-play-state: paused;
  }


  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
</style>
