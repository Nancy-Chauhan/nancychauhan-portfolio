---
---

<section class="relative">
  <div class="mx-auto max-w-6xl px-6 md:px-24 py-16 md:py-24">
    <div class="flex flex-col md:flex-row items-center gap-10">
      {/* Text */}
      <div class="text-center md:text-left order-2 md:order-1">
        <h1 class="text-[clamp(2.5rem,8vw,4.5rem)] font-extrabold font-sans tracking-tight leading-tight mb-6">
          <span class="text-gradient inline-block">Nancy</span> Chauhan
        </h1>

        <p class="text-lg md:text-xl text-[var(--color-stone-600)] font-sans leading-relaxed max-w-xl mb-3">
          I build and ship across AI, security, cloud, and open source. Always curious and learning.
        </p>

        <p class="font-sans text-lg text-[var(--color-stone-400)] mb-8">
          Engineer by day, product builder, and community cheerleader all rolled into one!
        </p>

        {/* CTA + social icons */}
        <div class="flex flex-wrap items-center justify-center md:justify-start gap-3">
          <a
            href="/projects"
            class="inline-flex items-center gap-2 px-6 py-3 bg-[var(--color-purple)] text-white font-sans font-semibold text-sm border-2 border-[var(--color-stone-800)] shadow-brutal-sm hover:bg-[var(--color-purple-dark)] transition-colors"
          >
            See what I built
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a
            href="https://github.com/Nancy-Chauhan"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center w-11 h-11 border-2 border-[var(--color-stone-800)] bg-white text-[var(--color-stone-700)] shadow-brutal-sm hover:border-[var(--color-purple)] hover:text-[var(--color-purple)] transition-colors"
            aria-label="GitHub"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 00-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0020 4.77 5.07 5.07 0 0019.91 1S18.73.65 16 2.48a13.38 13.38 0 00-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 005 4.77a5.44 5.44 0 00-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 009 18.13V22" /></svg>
          </a>
          <a
            href="https://www.linkedin.com/in/nancy-chauhan/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center w-11 h-11 border-2 border-[var(--color-stone-800)] bg-white text-[var(--color-stone-700)] shadow-brutal-sm hover:border-[var(--color-purple)] hover:text-[var(--color-purple)] transition-colors"
            aria-label="LinkedIn"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2zM4 6a2 2 0 100-4 2 2 0 000 4z" /></svg>
          </a>
          <a
            href="https://x.com/home"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center w-11 h-11 border-2 border-[var(--color-stone-800)] bg-white text-[var(--color-stone-700)] shadow-brutal-sm hover:border-[var(--color-purple)] hover:text-[var(--color-purple)] transition-colors"
            aria-label="Twitter"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z" /></svg>
          </a>
        </div>
      </div>

      {/* Photo */}
      <div class="shrink-0 order-1 md:order-2">
        <div class="w-48 h-48 md:w-56 md:h-56 border-2 border-[var(--color-stone-800)] shadow-brutal overflow-hidden">
          <img
            src="/nancy-speaking.jpeg"
            alt="Nancy Chauhan"
            class="w-full h-full object-cover object-[25%_center] hover:scale-105 transition-transform duration-500"
          />
        </div>
      </div>
    </div>
  </div>
</section>
