---
const talksData = await import("../../data/talks/talks.json");
const talks = talksData.default as {
  title: string; event: string; year: number; type: string; video?: string; coSpeaker?: string;
}[];

// Only show talks with videos, sorted by year descending
const videoTalks = talks
  .filter((t) => t.video)
  .sort((a, b) => b.year - a.year);

// Extract YouTube video ID from URL
function getYouTubeId(url: string) {
  const match = url.match(/(?:v=|\/)([\w-]{11})/);
  return match ? match[1] : null;
}

---

<section id="talks">
  <div class="mb-10 animate-on-scroll">
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
      <div>
        <h2 class="text-3xl md:text-4xl font-extrabold font-sans tracking-tight mb-3">
          <span class="section-heading">I Talk Tech at Conferences</span>
        </h2>
        <p class="text-lg text-[var(--color-stone-500)] font-sans">
          Sharing ideas on stage, from meetups to global events.
        </p>
      </div>
      <a
        href="https://www.youtube.com/playlist?list=PL-0wUDKSiP4rYhEiKlOQQ433nh1KxCOx1"
        target="_blank" rel="noopener noreferrer"
        class="hidden sm:inline-flex btn-brutal btn-brutal-secondary text-sm shrink-0"
      >
        All talks
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4 md:gap-5">
    {videoTalks.slice(0, 6).map((talk, i) => talk.video && (
      <a
        href={talk.video}
        target="_blank"
        rel="noopener noreferrer"
        class={`animate-on-scroll stagger-${i + 1} group card-brutal overflow-hidden flex flex-col`}
      >
        <div class="relative overflow-hidden">
          <img
            src={`https://img.youtube.com/vi/${getYouTubeId(talk.video)}/maxresdefault.jpg`}
            alt={talk.title}
            class="w-full aspect-video object-cover group-hover:scale-105 transition-transform duration-300"
            loading="lazy"
          />
        </div>
        <div class="p-3 flex items-start gap-2">
          <div class="shrink-0 mt-0.5">
            <svg class="w-6 h-6 text-red-500" viewBox="0 0 24 24" fill="currentColor">
              <circle cx="12" cy="12" r="12" opacity="0.15" />
              <path d="M9.5 7.5v9l7-4.5z" />
            </svg>
          </div>
          <p class="font-sans font-bold text-[var(--color-stone-900)] text-xs leading-snug">{talk.title}</p>
        </div>
      </a>
    ))}
  </div>

  <div class="mt-8 text-center sm:hidden">
    <a
      href="https://www.youtube.com/playlist?list=PL-0wUDKSiP4rYhEiKlOQQ433nh1KxCOx1"
      target="_blank" rel="noopener noreferrer"
      class="btn-brutal btn-brutal-secondary text-sm"
    >
      All talks
    </a>
  </div>
</section>

