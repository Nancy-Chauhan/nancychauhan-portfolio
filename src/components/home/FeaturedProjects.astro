---
import { getCollection } from "astro:content";
import ProjectCard from "../cards/ProjectCard.astro";

const projects = (await getCollection("projects"))
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
---

<section id="projects">
  <div class="flex items-end justify-between mb-10 animate-on-scroll">
    <div>
      <h2 class="text-3xl md:text-4xl font-extrabold font-sans tracking-tight mb-3">
        <span class="section-heading">Projects</span>
      </h2>
      <p class="text-lg text-[var(--color-stone-500)] font-sans">
        Tools and systems I've built.
      </p>
    </div>
    <a href="/projects" class="hidden sm:inline-flex btn-brutal btn-brutal-secondary text-sm">
      Explore more
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </a>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {projects.map((project, i) => (
      <div class={`animate-on-scroll stagger-${i + 1}`}>
        <ProjectCard
          title={project.data.title}
          tagline={project.data.tagline}
          techStack={project.data.techStack}
          slug={project.id}
        />
      </div>
    ))}
  </div>
  <div class="mt-8 text-center sm:hidden">
    <a href="/projects" class="btn-brutal btn-brutal-secondary text-sm">Explore more</a>
  </div>
</section>
