---

<section>
  <h2 class="text-3xl md:text-4xl font-extrabold font-sans tracking-tight mb-3 animate-on-scroll">
    <span class="section-heading">I find myself drawn to many things 😎</span>
  </h2>
  <p class="text-lg text-[var(--color-stone-500)] font-sans mb-10 animate-on-scroll">
    but I'm currently learning and growing most in this area.
  </p>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-8">
    {features.map((f, i) => (
      <div class={`animate-on-scroll stagger-${i + 1}`}>
        <div class="feature-card group bg-white border-2 border-[var(--color-stone-200)] p-5 h-full transition-all duration-300 hover:border-[var(--color-stone-800)] hover:shadow-brutal-sm">
          <div class="flex items-start gap-4">
            <div
              class="inline-flex items-center justify-center w-10 h-10 shrink-0 rounded-sm"
              style={`background-color: ${f.bg};`}
            >
              <svg class="w-5 h-5" style={`color: ${f.color};`} fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={f.icon} />
            </div>
            <div>
              <h3 class="text-base font-bold font-sans text-[var(--color-stone-900)] mb-1">{f.title}</h3>
              <p class="text-sm text-[var(--color-stone-500)] font-sans leading-relaxed">{f.description}</p>
            </div>
          </div>
        </div>
      </div>
    ))}
  </div></section>
