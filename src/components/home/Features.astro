---
const features = [
  {
    title: "All Things AI",
    description: "LLMs, agents, MCP, RAG, evals - exploring everything in AI.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" />`,
    color: "#2563eb",
    bg: "#eff6ff",
    tag: "Currently obsessed",
    rotate: "-1deg",
  },
  {
    title: "Security",
    description: "Breaking down systems to understand how they fail, helping teams build more secure products.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z" />`,
    color: "#059669",
    bg: "#ecfdf5",
    tag: "Love breaking things",
    rotate: "0.5deg",
  },
  {
    title: "Developer Experience",
    description: "Building tools that help developers ship faster. From CLIs to cloud environments.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085" />`,
    color: "#7c3aed",
    bg: "#f5f3ff",
    tag: "Tooling nerd",
    rotate: "-0.5deg",
  },
  {
    title: "Open Source & Community",
    description: "Founded Women in Cloud Native, GSoC mentor, K8s release team.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />`,
    color: "#f59e0b",
    bg: "#fffbeb",
    tag: "Community first",
    rotate: "1deg",
  },
];
---

<section>
  <h2 class="text-3xl md:text-4xl font-extrabold font-sans tracking-tight mb-3 animate-on-scroll">
    <span class="section-heading">What I Do</span>
  </h2>
  <p class="text-lg text-[var(--color-stone-500)] font-sans mb-10 animate-on-scroll">
    I find myself drawn to many things 😎<br />but I'm currently learning and growing most in this area.
  </p>
  <div class="flex flex-col md:flex-row gap-8 items-stretch">
    <div class="flex flex-col gap-3 md:w-1/2">
      {features.map((f, i) => (
        <div
          class={`feature-card animate-on-scroll stagger-${i + 1} group cursor-default`}
          style={`--accent: ${f.color}; --accent-bg: ${f.bg}; --card-rotate: ${f.rotate};`}
        >
          <div class="feature-inner relative overflow-hidden transition-all duration-300" style={`border-left: 4px solid ${f.color};`}>
            {/* Hover background wash */}
            <div class="feature-bg absolute inset-0 opacity-0 transition-opacity duration-300" style={`background-color: ${f.bg};`}></div>

            <div class="relative flex items-center gap-3 px-4 py-3">
              <div
                class="feature-icon inline-flex items-center justify-center w-9 h-9 border-2 border-[var(--color-stone-800)] shrink-0 transition-all duration-300"
                style={`background-color: ${f.color}; box-shadow: 2px 2px 0px 0px var(--color-stone-800);`}
              >
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={f.icon} />
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-0.5 flex-wrap">
                  <h3 class="text-sm font-bold font-sans text-[var(--color-stone-900)]">{f.title}</h3>
                  <span class="feature-tag text-[10px] font-bold font-sans uppercase tracking-wider px-2 py-0.5 border rounded-full transition-all duration-300 opacity-0 translate-x-2"
                    style={`color: ${f.color}; border-color: ${f.color}; background-color: ${f.bg};`}>
                    {f.tag}
                  </span>
                </div>
                <p class="text-xs text-[var(--color-stone-500)] font-sans leading-relaxed">{f.description}</p>
              </div>
              {/* Arrow that slides in on hover */}
              <svg class="feature-arrow w-5 h-5 text-[var(--color-stone-300)] shrink-0 transition-all duration-300 opacity-0 translate-x-[-8px]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </div>
        </div>
      ))}
    </div>
    <div class="hidden md:flex md:w-1/2">
      <div class="overflow-hidden border-2 border-[var(--color-stone-800)] shadow-brutal features-image-wrapper relative w-full">
        <img
          src="/nancy-speaking.jpeg"
          alt="Nancy Chauhan speaking at a conference"
          class="w-full h-full object-cover object-[25%_center] transition-transform duration-700 hover:scale-105"
        />
        <div class="absolute bottom-0 left-0 right-0 p-4 bg-gradient-to-t from-black/60 to-transparent">
          <p class="font-sans text-white text-sm font-bold">KubeCon + CloudNativeCon</p>
          <p class="font-sans text-white/70 text-xs">Speaking on stage</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .feature-inner {
    background: white;
    border: 2px solid var(--color-stone-800);
    box-shadow: 3px 3px 0px 0px var(--color-stone-800);
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
                box-shadow 0.3s ease,
                border-color 0.3s ease;
  }

  .feature-card {
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  /* Hover: card lifts, shadow grows, slight tilt */
  .feature-card:hover {
    transform: translateY(-3px) rotate(var(--card-rotate));
    z-index: 2;
  }
  .feature-card:hover .feature-inner {
    box-shadow: 4px 5px 0px 0px var(--color-stone-800);
    border-color: var(--accent);
  }

  /* Icon bounce */
  .feature-card:hover .feature-icon {
    transform: rotate(-8deg) scale(1.1);
  }

  /* Tag slides in */
  .feature-card:hover .feature-tag {
    opacity: 1;
    transform: translateX(0);
  }

  /* Background wash */
  .feature-card:hover .feature-bg {
    opacity: 1;
  }

  /* Arrow slides in */
  .feature-card:hover .feature-arrow {
    opacity: 1;
    transform: translateX(0);
    color: var(--accent);
  }

  .feature-icon {
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
</style>
