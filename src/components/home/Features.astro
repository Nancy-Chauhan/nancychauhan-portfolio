---
const features = [
  { title: "All Things AI", description: "LLMs, agents, MCP, RAG, and evals.", icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456z" />` },
  { title: "Security", description: "Breaking systems to build them better.", icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />` },
  { title: "Developer Experience", description: "CLIs, cloud tools, and dev workflows.", icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6.75 7.5l3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0021 18V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v12a2.25 2.25 0 002.25 2.25z" />` },
  { title: "Open Source & Community", description: "WiCN founder, GSoC, K8s Release Team.", icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />` },
];
---

<section>
  <div class="mb-10 animate-on-scroll">
    <h2 class="text-3xl md:text-4xl font-extrabold font-sans tracking-tight mb-2">
      What I Build & Explore
    </h2>
    <p class="text-lg text-[var(--color-stone-500)] font-sans">
      AI, security, developer tools, and open source.
    </p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
    {features.map((f, i) => (
      <div class={`animate-on-scroll stagger-${i + 1} card-brutal p-6`}>
        <div class="inline-flex items-center justify-center w-11 h-11 border-2 border-[var(--color-stone-800)] bg-white shadow-brutal-sm mb-4">
          <svg class="w-5 h-5 text-[var(--color-stone-700)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={f.icon} />
        </div>
        <h3 class="text-lg font-bold font-sans text-[var(--color-stone-900)] mb-2">{f.title}</h3>
        <p class="text-sm text-[var(--color-stone-500)] font-sans leading-relaxed">{f.description}</p>
      </div>
    ))}
  </div>
</section>
