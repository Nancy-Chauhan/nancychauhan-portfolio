---
const features = [
  { title: "All Things AI", description: "LLMs, agents, MCP, RAG, and evals.", image: "/features/ai.svg", bg: "#ede9fe" },
  { title: "Security", description: "Breaking systems to build them better.", image: "/features/security.svg", bg: "#fce7f3" },
  { title: "Developer Experience", description: "CLIs, cloud tools, and dev workflows.", image: "/features/devex.svg", bg: "#dbeafe" },
  { title: "Open Source", description: "WiCN founder, GSoC, K8s Release Team.", image: "/features/opensource.svg", bg: "#d1fae5" },
];
---

<section>
  <div class="mb-10 animate-on-scroll">
    <h2 class="text-3xl md:text-4xl font-extrabold font-sans tracking-tight mb-2">
      What I Build & Explore
    </h2>
    <p class="text-lg text-[var(--color-stone-500)] font-sans">
      AI, security, developer tools, and open source.
    </p>
  </div>

  <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-5">
    {features.map((f, i) => (
      <div class={`animate-on-scroll stagger-${i + 1} card-brutal overflow-hidden flex flex-col h-full`}>
        <div
          class="aspect-[4/3] flex items-center justify-center p-4 md:p-6 overflow-hidden border-b-2 border-[var(--color-stone-800)]"
          style={`background: ${f.bg};`}
        >
          <img
            src={f.image}
            alt={f.title}
            class="max-h-full max-w-full object-contain"
            loading="lazy"
          />
        </div>
        <div class="p-5 flex-1">
          <h3 class="text-base font-bold font-sans text-[var(--color-stone-900)] mb-1">{f.title}</h3>
          <p class="text-sm text-[var(--color-stone-500)] font-sans leading-relaxed">{f.description}</p>
        </div>
      </div>
    ))}
  </div>
</section>
