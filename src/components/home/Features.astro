---
const features = [
  { title: "All Things AI", description: "LLMs, agents, MCP, RAG, evals - exploring everything in AI.", image: "/features/ai.png" },
  { title: "Security", description: "Breaking down systems to understand how they fail, helping teams build more secure products.", image: "/features/security.png" },
  { title: "Developer Experience", description: "Building tools that help developers ship faster. From CLIs to cloud environments.", image: "/features/devex.png" },
  { title: "Open Source & Community", description: "Founded Women in Cloud Native, GSoC mentor, K8s release team.", image: "/features/opensource.png" },
];
---

<section class="animate-on-scroll">
  <div class="card-brutal p-8 md:p-12">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-10">
      <div>
        <h2 class="text-3xl md:text-4xl font-extrabold font-sans tracking-tight mb-2">
          I find myself drawn to many things
        </h2>
        <p class="text-lg text-[var(--color-stone-500)] font-sans">
          but I'm currently learning and growing most in this area.
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-0 border-t-2 border-[var(--color-stone-800)]">
      {features.map((f, i) => (
        <div class={`feature-item group p-5 md:p-6 ${i < 3 ? 'border-b-2 md:border-b-0 md:border-r-2 border-[var(--color-stone-200)] md:border-[var(--color-stone-200)]' : ''} ${i === 1 ? 'border-b-2 sm:border-r-0 md:border-r-2 border-[var(--color-stone-200)]' : ''} hover:bg-[var(--color-stone-50)] transition-colors`}>
          <div class="h-28 mb-4 flex items-center justify-center overflow-hidden">
            <img
              src={f.image}
              alt={f.title}
              class="max-h-full max-w-full object-contain group-hover:scale-105 transition-transform duration-300"
            />
          </div>
          <h3 class="text-base font-bold font-sans text-[var(--color-stone-900)] mb-2">{f.title}</h3>
          <p class="text-sm text-[var(--color-stone-500)] font-sans leading-relaxed">{f.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
