---
const features = [
  { title: "Product Thinking", description: "User research, roadmaps, and shipping ideas that stick.", image: "/features/ai.svg", bg: "#ede9fe" },
  { title: "All Things AI", description: "LLMs, agents, MCP, RAG, and evals.", image: "/features/devex.svg", bg: "#dbeafe" },
  { title: "Security", description: "Breaking systems to build them better.", image: "/features/security.svg", bg: "#fce7f3" },
  { title: "Open Source", description: "WiCN founder, GSoC, K8s Release Team.", image: "/features/opensource.svg", bg: "#d1fae5" },
];
---

<section>
  <div class="mb-10 animate-on-scroll">
    <h2 class="text-3xl md:text-4xl font-extrabold font-sans tracking-tight mb-2">
      What I Build & Ship
    </h2>
    <p class="text-lg text-[var(--color-stone-500)] font-sans">
      Product, AI, security, and open source.
    </p>
  </div>

  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 md:gap-5">
    {features.map((f, i) => (
      <div class={`animate-on-scroll stagger-${i + 1} card-brutal overflow-hidden flex flex-col h-full`}>
        <div
          class="aspect-[4/3] flex items-center justify-center p-3 md:p-6 overflow-hidden border-b-2 border-[var(--color-stone-800)]"
          style={`background: ${f.bg};`}
        >
          <img
            src={f.image}
            alt={f.title}
            class="max-h-full max-w-full object-contain"
            loading="lazy"
          />
        </div>
        <div class="p-3 md:p-5 flex-1">
          <h3 class="text-sm md:text-base font-bold font-sans text-[var(--color-stone-900)] mb-0.5 md:mb-1">{f.title}</h3>
          <p class="text-xs md:text-sm text-[var(--color-stone-500)] font-sans leading-relaxed">{f.description}</p>
        </div>
      </div>
    ))}
  </div>
</section>
