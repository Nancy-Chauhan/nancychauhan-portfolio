---
const socials = [
  { name: "GitHub", url: "https://github.com/Nancy-Chauhan", icon: `<path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" fill="currentColor"/>` },
  { name: "LinkedIn", url: "https://www.linkedin.com/in/nancy-chauhan/", icon: `<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" fill="currentColor"/>` },
  { name: "X", url: "https://x.com/_nancychauhan", icon: `<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" fill="currentColor"/>` },
];
---

<footer id="connect" class="border-t-2 border-dashed border-[var(--color-stone-300)] bg-[var(--color-cream)] py-16">
  <div class="mx-auto max-w-6xl px-6 md:px-24">
    <div class="flex flex-col md:flex-row items-start justify-between gap-10">
      <div>
        <h3 class="text-2xl md:text-3xl font-extrabold font-sans tracking-tight mb-3 text-[var(--color-stone-900)]">
          Let's connect<span class="text-[var(--color-purple)]">.</span>
        </h3>
        <p class="font-sans text-sm sm:text-base text-[var(--color-stone-400)] break-all sm:break-normal">
          $ nancy --connect --location="SF"<span class="terminal-cursor"></span>
        </p>
      </div>
      <div class="flex items-center gap-3">
        {socials.map((social) => (
          <a
            href={social.url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center w-10 h-10 border-2 border-[var(--color-stone-800)] bg-white text-[var(--color-stone-600)] shadow-brutal-sm hover:border-[var(--color-purple)] hover:text-[var(--color-purple)] transition-all duration-200"
            aria-label={social.name}
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" set:html={social.icon} />
          </a>
        ))}
      </div>
    </div>
    <div class="mt-10 pt-6 border-t-2 border-dashed border-[var(--color-stone-200)] text-left">
      <p class="text-xs text-[var(--color-stone-400)] font-sans">
        Building bridges and getting things done together 💜
      </p>
    </div>
  </div>
</footer>
