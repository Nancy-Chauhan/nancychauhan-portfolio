  { name: "Bluesky", url: "https://bsky.app/profile/nancychauhan.com", icon: `<path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm4.5 14.5h-2.1l-2.4-3.6-2.4 3.6H7.5L11 11 7.5 5.5h2.1L12 9.1l2.4-3.6h2.1L13 11l3.5 5.5z" fill="currentColor"/>` },
