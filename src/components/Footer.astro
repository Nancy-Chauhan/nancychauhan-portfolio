---

<footer class="border-t-2 border-dashed border-[var(--color-stone-300)] bg-[var(--color-cream)] py-16">
  <div class="mx-auto max-w-6xl px-6">
    <div class="flex flex-col md:flex-row items-center md:items-start justify-between gap-10">
      <div>
        <h3 class="text-2xl md:text-3xl font-extrabold font-sans tracking-tight mb-3 text-[var(--color-stone-900)]">
          Let's connect<span class="text-[var(--color-purple)]">.</span>
        </h3>
        <p class="font-sans text-sm text-[var(--color-stone-400)]">
          $ nancy --connect --location="San Francisco"<span class="terminal-cursor"></span>
        </p>
      </div>
      <div class="flex items-center gap-3">
        {socials.map((social) => (
          <a
            href={social.url}
            target="_blank"
            rel="noopener noreferrer"
            class="p-2.5 rounded-xl border-2 border-dashed border-[var(--color-stone-300)] text-[var(--color-stone-600)] hover:border-[var(--color-purple)] hover:text-[var(--color-purple)] transition-all duration-200"
            aria-label={social.name}
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" set:html={social.icon} />
          </a>
        ))}
      </div>
    </div>
    <div class="mt-10 pt-6 border-t-2 border-dashed border-[var(--color-stone-200)] text-center md:text-left">
      <p class="text-xs text-[var(--color-stone-400)] font-sans">
        &copy; {new Date().getFullYear()} Nancy Chauhan. Built with
        <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="text-[var(--color-purple)] hover:underline transition-colors">Astro</a>.
      </p>
    </div>
  </div>
</footer>
