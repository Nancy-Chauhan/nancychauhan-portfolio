---
const navLinks = [
  { href: "/", label: "Home" },
  { href: "/projects", label: "Projects" },
  { href: "/blog", label: "Blog" },
  { href: "/#talks", label: "Talks" },
  { href: "/about", label: "About" },
];

const currentPath = Astro.url.pathname;
---

<header class="w-full border-b border-[var(--color-stone-300)]">
  <nav class="mx-auto max-w-6xl px-6 py-5 flex items-center justify-between">
    <a href="/" class="font-sans text-sm font-bold text-[var(--color-stone-900)] hover:text-[var(--color-purple)] transition-colors">
      Nancy Chauhan
    </a>

    {/* Desktop nav */}
    <div class="hidden md:flex items-center gap-6">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            "font-sans text-sm font-medium transition-colors duration-200",
            currentPath === link.href || (link.href !== "/" && currentPath.startsWith(link.href))
              ? "text-[var(--color-purple)]"
              : "text-[var(--color-stone-600)] hover:text-[var(--color-stone-900)]",
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>

    {/* Mobile menu button */}
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 text-[var(--color-stone-600)] hover:bg-[var(--color-stone-100)] transition-colors"
      aria-label="Toggle menu"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  {/* Mobile menu */}
  <div
    id="mobile-menu"
    class="hidden md:hidden px-6 pb-4"
  >
    <div class="flex flex-col gap-1">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            "px-3 py-2 font-sans text-sm font-medium transition-colors duration-200",
            currentPath === link.href || (link.href !== "/" && currentPath.startsWith(link.href))
              ? "text-[var(--color-purple)]"
              : "text-[var(--color-stone-600)] hover:text-[var(--color-stone-900)] hover:bg-[var(--color-stone-100)]",
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  function initMobileMenu() {
    const btn = document.getElementById("mobile-menu-btn");
    const menu = document.getElementById("mobile-menu");
    const icon = document.getElementById("menu-icon");
    btn?.addEventListener("click", () => {
      const isOpen = !menu?.classList.contains("hidden");
      menu?.classList.toggle("hidden");
      if (icon) {
        icon.setAttribute("d", isOpen ? "M4 6h16M4 12h16M4 18h16" : "M6 18L18 6M6 6l12 12");
      }
    });
  }
  initMobileMenu();
  document.addEventListener("astro:page-load", initMobileMenu);
</script>
