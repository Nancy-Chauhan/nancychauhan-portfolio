---
interface Props {
  techStack: string[];
}

const { techStack } = Astro.props;
---

{techStack.length > 0 && (
  <section class="py-12">
    <h2 class="text-3xl md:text-4xl font-extrabold font-sans tracking-tight mb-6 animate-on-scroll">
      <span class="section-heading">Tech Stack</span>
    </h2>
    <div class="flex flex-wrap gap-3 animate-on-scroll">
      {techStack.map((tech) => (
        <span class="tag-brutal text-sm px-4 py-2">{tech}</span>
      ))}
    </div>
  </section>
)}
