---
const row1 = [
  "IMG_20191015_231543_120.jpg",
  "IMG_20191020_212458_301.jpg",
  "IMG_20230705_230147_929.jpg",
  "IMG_20240214_190414_631.jpg",
  "IMG_20240704_140041_613.jpg",
  "IMG_20250103_174227_963.jpg",
  "IMG_20251005_180417_354.jpg",
  "SCR-20260124-lbzv.jpeg",
  "SCR-20260124-lcbl.jpeg",
  "SCR-20260124-lcjc.jpeg",
];

const row2 = [
  "SCR-20260124-lcok.jpeg",
  "SCR-20260124-lcsm.jpeg",
  "SCR-20260124-lcuj.jpeg",
  "SCR-20260124-lczl.jpeg",
  "SCR-20260124-ldbg.jpeg",
  "SCR-20260124-ldhb.jpeg",
  "SCR-20260124-ldpa.jpeg",
  "SCR-20260124-lerf.jpeg",
  "SCR-20260124-leux.png",
  "SCR-20260124-lews.png",
  "SCR-20260128-rdba.jpeg",
];
---

<section>
  <div class="overflow-hidden rounded-lg">
    <div class="gallery-track gallery-left">
      {[...row1, ...row1].map((img) => (
        <div class="gallery-item">
          <img src={`/gallery/${img}`} alt="" loading="lazy" />
        </div>
      ))}
    </div>
  </div>

  <div class="overflow-hidden rounded-lg mt-3">
    <div class="gallery-track gallery-right">
      {[...row2, ...row2].map((img) => (
        <div class="gallery-item">
          <img src={`/gallery/${img}`} alt="" loading="lazy" />
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .gallery-track {
    display: flex;
    gap: 0.5rem;
    width: max-content;
  }

  .gallery-left {
    animation: gallery-scroll-left var(--gallery-duration, 30s) linear infinite;
  }

  .gallery-right {
    animation: gallery-scroll-right var(--gallery-duration, 30s) linear infinite;
  }

  .gallery-item {
    flex-shrink: 0;
    width: 110px;
    height: 140px;
    border-radius: 8px;
    overflow: hidden;
  }

  .gallery-item img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (min-width: 480px) {
    .gallery-item {
      width: 140px;
      height: 180px;
      border-radius: 10px;
    }

    .gallery-track {
      gap: 0.75rem;
    }
  }

  @media (min-width: 640px) {
    .gallery-item {
      width: 170px;
      height: 220px;
      border-radius: 12px;
    }

    .gallery-track {
      gap: 1rem;
    }
  }

  @keyframes gallery-scroll-left {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @keyframes gallery-scroll-right {
    0% { transform: translateX(-50%); }
    100% { transform: translateX(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .gallery-left, .gallery-right {
      animation: none;
    }
  }
</style>

<script>
  function initGallerySpeed() {
    const PIXELS_PER_SECOND = 50;
    document.querySelectorAll('.gallery-track').forEach((track) => {
      const halfWidth = track.scrollWidth / 2;
      const duration = halfWidth / PIXELS_PER_SECOND;
      (track as HTMLElement).style.setProperty('--gallery-duration', `${duration}s`);
    });
  }
  initGallerySpeed();
  document.addEventListener('astro:page-load', initGallerySpeed);
</script>
